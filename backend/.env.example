# Server Port configuration (defaults to 5000)
PORT=5000

# Node Environment (development / production)
NODE_ENV=development

# Database connection URL (Supabase PostgreSQL / local PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# JWT configuration
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=24h

# Allowed CORS origin in production (Vercel deployment URL)
FRONTEND_URL=https://your-frontend-app.vercel.app
